# ==========================================
# Variables de Entorno para Producción
# CIA SERVICIOS
# ==========================================
# 
# INSTRUCCIONES:
# 1. Copia este archivo como .env
# 2. Reemplaza TODOS los valores con tus datos reales
# 3. NUNCA compartas este archivo
#
# ==========================================

# ========== DOMINIO ==========
# Tu dominio sin https://
DOMAIN=tudominio.com.mx
FRONTEND_URL=https://tudominio.com.mx

# ========== SEGURIDAD ==========
# Genera claves seguras en: https://randomkeygen.com/
JWT_SECRET=CAMBIA-ESTO-genera-una-clave-de-32-caracteres-minimo
SUPER_ADMIN_KEY=CAMBIA-ESTO-tu-clave-maestra-secreta

# ========== MONGODB ==========
# Si usas MongoDB Atlas (recomendado):
# MONGO_URL=mongodb+srv://usuario:password@cluster.xxxxx.mongodb.net/cia_servicios
# 
# Si usas MongoDB local (incluido en docker-compose):
MONGO_URL=mongodb://mongodb:27017/cia_servicios
DB_NAME=cia_servicios

# ========== STRIPE (Pagos con tarjeta) ==========
# Obtén tus claves en: https://dashboard.stripe.com/apikeys
# Deja vacío si no usas Stripe
STRIPE_API_KEY=sk_live_XXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXX

# ========== EMAIL (SendGrid) ==========
# Obtén tu API key en: https://app.sendgrid.com/settings/api_keys
# Deja vacío si no envías emails
SENDGRID_API_KEY=SG.XXXXXXXXXXXXXX
EMAIL_FROM=notificaciones@tudominio.com.mx

# ========== FACTURAMA (Facturación Electrónica) ==========
# Obtén credenciales en: https://www.facturama.mx
# Deja vacío si no facturas
FACTURAMA_USER=tu_usuario_facturama
FACTURAMA_PASSWORD=tu_password_facturama
FACTURAMA_ENVIRONMENT=production

# ========== OPENAI (Inteligencia Artificial) ==========
# Obtén tu API key en: https://platform.openai.com/api-keys
# Deja vacío si no usas IA
OPENAI_API_KEY=sk-XXXXXXXXXXXXXX
